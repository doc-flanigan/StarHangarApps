# Copy this file to .env and fill in your credentials
# .env is gitignored — never commit real credentials

SH_EMAIL=your@email.com
SH_PASSWORD=yourpassword

# Autofill behavior (uncomment to override defaults)
# DRY_RUN=false       # set to false to actually submit forms (default: true = dry run only)
# LIMIT=5             # process only N listings per run (default: 0 = all)
# START_FROM=1        # skip to row N, 1-based (default: 1 = start from beginning)
