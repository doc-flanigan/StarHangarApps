# Copy this to .env and fill in your values
# then: source .env  (bash/zsh)

# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: connect to your already-open Chrome browser
# Launch Chrome with:  google-chrome --remote-debugging-port=9222
# Then set this variable so the agent uses that window instead of opening a new one.
CHROME_CDP_URL=http://localhost:9222
